{
  "version": 2,
  "builds": [
    {
      "src": "server-free.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server-free.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "GROQ_API_KEY": "@groq-api-key",
    "JWT_SECRET": "your_super_secret_jwt_key_here_123456789"
  }
}
